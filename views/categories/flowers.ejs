    <div class="add-new">
        <button><a href="/addnew">Click to add new</a></button>
        <p>List of the available agrocommodities for sales</p>
    </div>
    <div class="general-content">
        <%if(seedlings.length === 0){%>
            <div class="no-products">
                <p>No product at the moment, please check back later</p>
            </div>
        <%}else{%>
            <%seedlings.forEach(function(crops){%>
                <div class="content">
                    <a href="/<%=crops._id%>">
                        <img height="auto" width="100%" src="<%= crops.image[0].url%>" alt="<%=crops.name%> for sales"/>
                        <div class="content-desc">
                            <h1><%=crops.name%></h1>
                            <p><%=crops.description%></p>
                        </div>
                        <button class="frontBtn">See more</button>
                    </a>
                </div>
                <div class="pagination">
                    <% if (currentPage > 1) { %>
                        <a href="/flowers?page=<%= currentPage - 1 %>" class="page-btn">Previous</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/flowers?page=<%= i %>" 
                            class="page-number <%= i === currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/flowers?page=<%= currentPage + 1 %>" class="page-btn">Next</a>
                    <% } %>
              </div>
            <%})%>
        <%}%>
    
</div>
